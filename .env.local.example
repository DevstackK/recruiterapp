# Anthropic
ANTHROPIC_API_KEY=

# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase (Project Settings -> Database -> Connection string)
# Transaction pooler (port 6543) -- used by the running app; supports many short-lived connections.
DATABASE_URL=
# Session pooler (port 5432) -- used ONLY by drizzle-kit CLI (migrate/generate need session-level
# features transaction pooling doesn't support). Same host/user/password as above, different port.
DIRECT_URL=

# Google OAuth (Gmail API) - from Google Cloud Console
# GOOGLE_OAUTH_REDIRECT_URI must exactly match a redirect URI registered on the OAuth client,
# and must point at this app's /api/gmail/callback route (e.g. https://<app>.vercel.app/api/gmail/callback,
# or http://localhost:3000/api/gmail/callback for local testing).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=

# 32-byte key for encrypting the stored Gmail refresh token, base64-encoded.
# Generate with: openssl rand -base64 32
GMAIL_TOKEN_ENCRYPTION_KEY=

# Cron
CRON_SECRET=

# Postiz (self-hosted or cloud) -- auto-posts a hiring announcement to LinkedIn whenever
# a job is created. Get the API key from Postiz Settings -> Developers -> Public API.
# POSTIZ_LINKEDIN_INTEGRATION_ID is the integration/channel id for the LinkedIn account to
# post as (GET {POSTIZ_BASE_URL}/integrations to find it -- match by "identifier": "linkedin").
POSTIZ_API_KEY=
POSTIZ_BASE_URL=
POSTIZ_LINKEDIN_INTEGRATION_ID=

# Public base URL of this app -- used to build the apply link included in LinkedIn posts.
NEXT_PUBLIC_APP_URL=
